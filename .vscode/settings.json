{
  "files.watcherExclude": {
    "**/routeTree.gen.ts": true
  },
  "search.exclude": {
    "**/routeTree.gen.ts": true
  },
  "files.readonlyInclude": {
    "**/routeTree.gen.ts": true
  },
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[css]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "editor.codeActionsOnSave": {
    "source.organizeImports.biome": "explicit"
  },
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#5ddff8",
    "activityBar.background": "#5ddff8",
    "activityBar.foreground": "#15202b",
    "activityBar.inactiveForeground": "#15202b99",
    "activityBarBadge.background": "#f629d5",
    "activityBarBadge.foreground": "#e7e7e7",
    "commandCenter.border": "#15202b99",
    "sash.hoverBorder": "#5ddff8",
    "statusBar.background": "#2cd6f6",
    "statusBar.foreground": "#15202b",
    "statusBarItem.hoverBackground": "#0ac2e5",
    "statusBarItem.remoteBackground": "#2cd6f6",
    "statusBarItem.remoteForeground": "#15202b",
    "titleBar.activeBackground": "#2cd6f6",
    "titleBar.activeForeground": "#15202b",
    "titleBar.inactiveBackground": "#2cd6f699",
    "titleBar.inactiveForeground": "#15202b99"
  },
  "peacock.color": "#2cd6f6"
}
